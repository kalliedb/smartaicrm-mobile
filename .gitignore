# OSX
.DS_Store

# Native projects — GENERATED by `expo prebuild`, never commit.
# The source of truth is app.config.js + app.json + config plugins.
android/
ios/

# Xcode / iOS
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata
*.xccheckout
*.moved-aside
DerivedData
*.hmap
*.ipa
*.xcuserstate
ios/.xcode.env.local
ios/Pods/
ios/Podfile.lock

# Android / IntelliJ
*.iml
.idea/
.gradle/
local.properties
*.hprof
.cxx/
*.keystore
!debug.keystore
android/app/release/
android/build/
android/.gradle/
android/captures/

# Node / Metro / React Native
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.metro-health-check*
.expo/
.bundle/

# Builds + caches
ios/.xcode.env.local
*.tsbuildinfo

# Coverage
coverage/
.nyc_output/

# Secrets — NEVER commit
.env
.env.local
.env.*.local
*.p8                # Apple Push key
*.mobileprovision   # provisioning profiles
*.jks               # Android keystores

# credentials/ — release keystore + SECRETS.txt live here locally
credentials/*
!credentials/README.md
!credentials/SECRETS.txt.example

# Ruby / Fastlane
vendor/bundle/
fastlane/report.xml
fastlane/README.md
fastlane/asc_api_key.p8

# Misc
.vscode/*.local
*.log
.cache/
.eslintcache
