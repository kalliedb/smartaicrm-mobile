{
  "name": "aivera-field",
  "version": "0.1.0",
  "private": true,
  "description": "Aivera Field — mobile app for SA field technicians. Talks to api.smartaicrm.co.za.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
