    "axios": "^1.7.9",
    "expo": "54.0.33",
    "expo-constants": "~17.2.6",
    "expo-image-picker": "~16.1.4",
    "expo-location": "~18.2.4",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.2.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-keychain": "9.2.2",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.0",
    "zustand": "^5.0.2"
