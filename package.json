    "babel-preset-expo": "~13.0.0",
    "@types/jest": "^29.5.13",
    "@types/react": "~19.0.10",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.6.3"
