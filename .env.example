# Optional shell env for local dev. app.config.js reads these at
# `expo prebuild` time and inlines them into the build via
# Constants.expoConfig.extra.
#
# Copy to `.env` for a persistent override, or export in your shell before
# `npm run android`. NEVER commit the real .env.
#
# The default (no override) already points at production api.smartaicrm.co.za.

# Backend base URL — the axios client appends /api/v1 automatically.
EXPO_PUBLIC_BACKEND_URL=https://api.smartaicrm.co.za
