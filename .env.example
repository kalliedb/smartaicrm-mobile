# Copy this file to `.env` and fill in. NEVER commit the real .env.
# Loaded at build time by react-native-config.

# API base URL — production custom domain.
API_BASE_URL=https://api.smartaicrm.co.za/api/v1

# Bumped by CI; reflected in the About screen + crash reports.
APP_VERSION=0.1.0-dev

# development | staging | production
NODE_ENV=development

# Yoco mobile SDK keys (added in sprint M-5).
# YOCO_PUBLIC_KEY=
# YOCO_TAP_TO_PAY_MERCHANT_ID=

# Voice / AI gateway (added in sprint M-6). Not required for MVP-1 build.
# OPENAI_WHISPER_PROXY_URL=
